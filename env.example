# Credenciais eRede
REDE_MERCHANT_ID=your_merchant_id_here
REDE_MERCHANT_KEY=your_merchant_key_here

# Ambiente (sandbox ou production)
REDE_ENVIRONMENT=sandbox

# Endpoints OAuth
REDE_SANDBOX_OAUTH_ENDPOINT=https://rl7-sandbox-api.useredecloud.com.br/oauth2/token
REDE_PRODUCTION_OAUTH_ENDPOINT=https://api.userede.com.br/erede/oauth2/token

# Tokenização de Bandeira (Card Brand Tokenization)
# URL de webhook para receber eventos do ciclo de vida do token.
# Em produção o registro é feito pelo Portal Logado; em sandbox use esta variável.
# Exemplos: https://meusite.com/webhook/rede-token  |  https://webhook.site/<uuid>
REDE_TOKENIZATION_WEBHOOK_URL=https://webhook.site/rede-tokenization-test

